{
  "name": "unisphere-server",
  "version": "1.0.0",
  "description": "UniSphere API Server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed": "ts-node src/scripts/seedDatabase.ts",
    "test:registration": "ts-node --transpile-only tests/registration.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.24.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.13",
    "zod": "^3.22.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.43",
    "@types/nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
